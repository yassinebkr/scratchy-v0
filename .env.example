# Scratchy v0 — Environment Variables
# Copy this to .env and fill in your values

# ElevenLabs TTS (optional)
ELEVENLABS_API_KEY=

# Resend Email API (optional, for email widget)
RESEND_API_KEY=

# OpenClaw Gateway
OPENCLAW_GATEWAY_URL=http://localhost:28945
OPENCLAW_API_KEY=

# Google Calendar/YouTube OAuth (optional)
GCAL_CREDS_PATH=
GCAL_SESSION_PATH=

# Server
PORT=3001
HOST=0.0.0.0
