{
  "catalogId": "https://your-domain.example.com/catalog/v2",
  "version": "2.0.0",
  "components": {
    "Hero": {
      "description": "Hero banner with title, subtitle, and background",
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "background": { "type": "string" }
      }
    },
    "Gauge": {
      "description": "Circular or arc gauge displaying a numeric value",
      "properties": {
        "label": { "type": "string" },
        "value": { "type": "number" },
        "max": { "type": "number" },
        "unit": { "type": "string" },
        "color": { "type": "string" }
      }
    },
    "Progress": {
      "description": "Progress bar with label and value",
      "properties": {
        "label": { "type": "string" },
        "value": { "type": "number" },
        "max": { "type": "number" }
      }
    },
    "Weather": {
      "description": "Weather card with icon, city, temp, condition",
      "properties": {
        "icon": { "type": "string" },
        "city": { "type": "string" },
        "temp": { "type": "string" },
        "condition": { "type": "string" }
      }
    },
    "Alert": {
      "description": "Alert banner with type, title, message, and severity",
      "properties": {
        "type": { "type": "string", "enum": ["info", "warning", "error", "success"] },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "severity": { "type": "string" }
      }
    },
    "Stats": {
      "description": "Statistics card with title and key-value items",
      "properties": {
        "title": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "value": { "type": "string" }
            }
          }
        }
      }
    },
    "Checklist": {
      "description": "Checklist with toggleable items",
      "properties": {
        "title": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "text": { "type": "string" },
              "checked": { "type": "boolean" }
            }
          }
        }
      }
    },
    "Card": {
      "description": "Generic card with title, body, and footer",
      "properties": {
        "title": { "type": "string" },
        "body": { "type": "string" },
        "footer": { "type": "string" }
      }
    },
    "Kv": {
      "description": "Key-value list with title",
      "properties": {
        "title": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "key": { "type": "string" },
              "value": { "type": "string" }
            }
          }
        }
      }
    },
    "Buttons": {
      "description": "Group of action buttons",
      "properties": {
        "buttons": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "action": { "type": "string" },
              "style": { "type": "string" }
            }
          }
        }
      }
    },
    "Timeline": {
      "description": "Vertical timeline of events",
      "properties": {
        "title": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "detail": { "type": "string" },
              "time": { "type": "string" }
            }
          }
        }
      }
    },
    "Tags": {
      "description": "Tag cloud with optional color",
      "properties": {
        "title": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "color": { "type": "string" }
      }
    },
    "Table": {
      "description": "Data table with headers and rows",
      "properties": {
        "title": { "type": "string" },
        "headers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "rows": {
          "type": "array",
          "items": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "Sparkline": {
      "description": "Inline sparkline chart",
      "properties": {
        "values": {
          "type": "array",
          "items": { "type": "number" }
        },
        "label": { "type": "string" },
        "color": { "type": "string" },
        "height": { "type": "number" }
      }
    },
    "Code": {
      "description": "Syntax-highlighted code block",
      "properties": {
        "language": { "type": "string" },
        "code": { "type": "string" },
        "title": { "type": "string" }
      }
    },
    "Accordion": {
      "description": "Collapsible accordion sections",
      "properties": {
        "title": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "content": { "type": "string" }
            }
          }
        }
      }
    },
    "StackedBar": {
      "description": "Horizontal stacked bar chart",
      "properties": {
        "title": { "type": "string" },
        "segments": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "value": { "type": "number" },
              "color": { "type": "string" }
            }
          }
        },
        "total": { "type": "number" }
      }
    },
    "FormStrip": {
      "description": "Compact inline form strip",
      "properties": {
        "fields": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "value": { "type": "string" }
            }
          }
        },
        "action": { "type": "string" }
      }
    },
    "LinkCard": {
      "description": "Link preview card with image",
      "properties": {
        "title": { "type": "string" },
        "url": { "type": "string" },
        "description": { "type": "string" },
        "image": { "type": "string" }
      }
    },
    "Status": {
      "description": "Status indicator with label and detail",
      "properties": {
        "label": { "type": "string" },
        "status": { "type": "string", "enum": ["online", "offline", "warning", "error"] },
        "detail": { "type": "string" }
      }
    },
    "Form": {
      "description": "Dynamic form with fields and actions",
      "properties": {
        "title": { "type": "string" },
        "fields": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "type": { "type": "string" },
              "label": { "type": "string" },
              "value": { "type": "string" },
              "placeholder": { "type": "string" },
              "options": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "actions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "action": { "type": "string" },
              "style": { "type": "string" }
            }
          }
        }
      }
    },
    "Streak": {
      "description": "Streak/heatmap visualization",
      "properties": {
        "title": { "type": "string" },
        "data": {
          "type": "array",
          "items": { "type": ["number", "boolean"] }
        },
        "labels": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "Rating": {
      "description": "Star or numeric rating display",
      "properties": {
        "label": { "type": "string" },
        "value": { "type": "number" },
        "max": { "type": "number" }
      }
    },
    "Chips": {
      "description": "Chip/pill collection",
      "properties": {
        "title": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "object",
                "properties": {
                  "label": { "type": "string" },
                  "color": { "type": "string" }
                }
              }
            ]
          }
        }
      }
    },
    "Toggle": {
      "description": "Boolean toggle switch",
      "properties": {
        "label": { "type": "string" },
        "value": { "type": "boolean" },
        "description": { "type": "string" }
      }
    },
    "Input": {
      "description": "Text input field",
      "properties": {
        "label": { "type": "string" },
        "placeholder": { "type": "string" },
        "value": { "type": "string" },
        "type": { "type": "string" }
      }
    },
    "Slider": {
      "description": "Numeric range slider",
      "properties": {
        "label": { "type": "string" },
        "value": { "type": "number" },
        "min": { "type": "number" },
        "max": { "type": "number" },
        "step": { "type": "number" }
      }
    },
    "Tabs": {
      "description": "Tabbed content panels",
      "properties": {
        "tabs": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "content": { "type": "string" }
            }
          }
        },
        "activeIndex": { "type": "number" }
      }
    },
    "Video": {
      "description": "Video player with poster and title",
      "properties": {
        "src": { "type": "string" },
        "poster": { "type": "string" },
        "title": { "type": "string" }
      }
    },
    "Image": {
      "description": "Image with alt text and caption",
      "properties": {
        "src": { "type": "string" },
        "alt": { "type": "string" },
        "caption": { "type": "string" }
      }
    },
    "ChartBar": {
      "description": "Bar chart with labeled datasets",
      "properties": {
        "title": { "type": "string" },
        "labels": {
          "type": "array",
          "items": { "type": "string" }
        },
        "datasets": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "data": { "type": "array", "items": { "type": "number" } },
              "color": { "type": "string" }
            }
          }
        }
      }
    },
    "ChartLine": {
      "description": "Line chart with labeled datasets",
      "properties": {
        "title": { "type": "string" },
        "labels": {
          "type": "array",
          "items": { "type": "string" }
        },
        "datasets": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "data": { "type": "array", "items": { "type": "number" } },
              "color": { "type": "string" }
            }
          }
        }
      }
    },
    "ChartPie": {
      "description": "Pie/donut chart with colored segments",
      "properties": {
        "title": { "type": "string" },
        "segments": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "value": { "type": "number" },
              "color": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
